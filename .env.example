# ---- ANTHROPIC (Claude AI) ----
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXX

# ---- FACEBOOK / MESSENGER ----
# Obtén estos en: developers.facebook.com
FACEBOOK_PAGE_ACCESS_TOKEN=EAAXXXXXXXXXXX
FACEBOOK_VERIFY_TOKEN=mi_token_secreto_123  # Puedes elegir cualquier texto
FACEBOOK_APP_SECRET=XXXXXXXXXXXXXXXX
FACEBOOK_PAGE_ID=123456789

# ---- WHATSAPP BUSINESS ----
# Obtén estos en: developers.facebook.com (WhatsApp Business API)
